# Copy this file to .env and fill in real values. The .env file is gitignored.
# spring-dotenv loads these into the Spring Environment at startup.

# JWT signing secret (base64-encoded, >= 32 bytes decoded). Optional in dev —
# application.properties falls back to a working default if this is unset.
JWT_SECRET=your_base64_jwt_secret_here

# Stripe SECRET key (sk_test_... or sk_live_...). Backend only — never the frontend.
# Get it at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# OpenAI API key for AI image description/search. Leave empty to disable the feature.
OPENAI_API_KEY=sk-proj-your_openai_key

# Chroma vector store (AI image similarity search).
CHROMA_KEY_TOKEN=ck-your_chroma_token
CHROMA_TENANT=your_chroma_tenant_uuid
